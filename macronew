-- ===== Macro PC (Throw / Pull) | KEY E ONLY =====
do
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local UserInputService = game:GetService("UserInputService")
    local LocalPlayer = Players.LocalPlayer

    -- ===== MACRO LOGIC =====
    local winchSettings = {
        on  = { Speed = 1200000000, Responsiveness = 15000, Target = 5 },
        off = { Speed = 1300, Responsiveness = 8000, Target = 1e12 },
    }

    local THROW_ACCEL, UP_ACCEL, THROW_TIME = 120, 35, 0.12
    local isActive = true

    local function getHRP()
        local c = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        return c:FindFirstChild("HumanoidRootPart")
    end

    local function getMainRope()
        local c = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        for _, d in ipairs(c:GetDescendants()) do
            if d:IsA("RopeConstraint") then return d end
        end
        for _, d in ipairs(workspace:GetDescendants()) do
            if d:IsA("RopeConstraint") then
                local a, b = d.Attachment0, d.Attachment1
                if a and a.Parent and a.Parent:IsDescendantOf(c) then return d end
                if b and b.Parent and b.Parent:IsDescendantOf(c) then return d end
            end
        end
        return nil
    end

    local function applyWinch(rope, preset)
        if not rope then return end
        pcall(function()
            rope.WinchEnabled = true
            rope.WinchSpeed = preset.Speed
            rope.WinchResponsiveness = preset.Responsiveness
            rope.WinchTarget = preset.Target
        end)
    end

    local function throwPlayerSmoothFast()
        local hrp = getHRP()
        if not hrp then return end

        local look = hrp.CFrame.LookVector
        local dir = Vector3.new(look.X, 0, look.Z)
        dir = (dir.Magnitude < 0.01) and Vector3.new(0,0,-1) or dir.Unit

        local att = Instance.new("Attachment", hrp)
        local vf = Instance.new("VectorForce")
        vf.Attachment0 = att
        vf.RelativeTo = Enum.ActuatorRelativeTo.World
        vf.ApplyAtCenterOfMass = true
        vf.Parent = hrp

        local mass = hrp.AssemblyMass
        local t0 = os.clock()

        local conn
        conn = RunService.Heartbeat:Connect(function()
            local t = os.clock() - t0
            if t >= THROW_TIME then
                vf.Force = Vector3.zero
                conn:Disconnect()
                att:Destroy()
                vf:Destroy()
                return
            end

            local a = math.clamp(t / THROW_TIME, 0, 1)
            vf.Force = (dir * THROW_ACCEL + Vector3.new(0, UP_ACCEL, 0)) * mass * a
        end)
    end

    local function applyState()
        local rope = getMainRope()

        if isActive then
            applyWinch(rope, winchSettings.on)
        else
            applyWinch(rope, winchSettings.off)
            throwPlayerSmoothFast()
        end
    end

    -- ===== KEY E (PC ONLY) =====
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end

        if input.UserInputType == Enum.UserInputType.Keyboard
            and input.KeyCode == Enum.KeyCode.E then

            isActive = not isActive
            applyState()
        end
    end)

    applyState()
end
